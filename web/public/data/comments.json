  },
  {
   "id": 5656619568332800,
   "authorId": 5718998062727168,
   "text": "は？",
   "tpos": 17.838956,
   "bone": "2017-06-11T08:18:46.324230+00:00"
  },
  {
   "id": 5639026912526336,
   "authorId": 5123639896702976,
   "text": "特定の再生回数を超えた場合、プロランキングに入れるとかできないかな",
   "tpos": 34.418298,
   "bone": "2018-12-01T15:06:48.464426+00:00"
  },
  {
   "id": 4807731454148608,
   "authorId": 6207962867564544,
   "text": "それはそう",
   "tpos": 41.191217,
   "bone": "2024-06-14T18:53:06.254302+00:00"
  },
  {
   "id": 5397938788368384,
   "authorId": 5730082031140864,
   "text": "そうだね",
   "tpos": 46.700118,
   "bone": "2017-04-10T08:59:32.545260+00:00"
  },
  {
   "id": 6238231347593216,
   "authorId": 6207962867564544,
   "text": "ノンケは分けろ",
   "tpos": 49.974267,
   "bone": "2024-06-14T18:53:14.979425+00:00"
  },
  {
   "id": 5994015480610816,
   "authorId": 6207962867564544,
   "text": "そだね",
   "tpos": 52.968764,
   "bone": "2024-06-14T18:53:17.970661+00:00"
  },
  {
   "id": 4832086837952512,
   "authorId": 6207962867564544,
   "text": "てかこれ背景からしてコメント未エズラ",
   "tpos": 62.738603,
   "bone": "2024-06-14T18:53:27.745372+00:00"
  },
  {
   "id": 4794418968133632,
   "authorId": 6207962867564544,
   "text": "でも面白い",
   "tpos": 68.08692,
   "bone": "2024-06-14T18:53:48.070038+00:00"
  },
  {
   "id": 5639574185312256,
   "authorId": 5130467284090880,
   "text": "やったぜ",
   "tpos": 85.967567,
   "bone": "2017-05-25T08:37:07.471100+00:00"
  },
  {
   "id": 6206716152643584,
   "authorId": 6207962867564544,
   "text": "これ以降は見なくていい",
   "tpos": 98.01543,
   "bone": "2024-06-14T18:54:39.764988+00:00"
  },
  {
   "id": 5747610597982208,
   "authorId": 5716646702350336,
   "text": "もっと人増えて欲しいけど、あまり増えすぎると荒れそうで怖い",
